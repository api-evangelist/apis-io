          "rules": [
            {
              "id": "owasp-api1-bola-operation-security-defined",
              "name": "owasp-api1-bola-operation-security-defined",
              "shortDescription": {
                "text": "API1 (BOLA): operation must declare a `security` requirement so per-object authorization can be enforced."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://docs.stoplight.io/docs/spectral/"
            },
            {
              "id": "owasp-api4-resource-string-maxlength",
              "name": "owasp-api4-resource-string-maxlength",
              "shortDescription": {
                "text": "API4 (Resource Consumption): string schema should declare `maxLength` to bound input size."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://docs.stoplight.io/docs/spectral/"
            },
            {
              "id": "owasp-api4-resource-integer-bounds",
              "name": "owasp-api4-resource-integer-bounds",
              "shortDescription": {
                "text": "API4 (Resource Consumption): numeric schema should declare a `maximum` (e.g. cap page size)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://docs.stoplight.io/docs/spectral/"
            },
            {
              "id": "owasp-api4-resource-array-maxitems",
              "name": "owasp-api4-resource-array-maxitems",
              "shortDescription": {
                "text": "API4 (Resource Consumption): array schema should declare `maxItems` to bound collection size."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://docs.stoplight.io/docs/spectral/"
            },
            {
              "id": "owasp-api7-ssrf-url-property-format",
              "name": "owasp-api7-ssrf-url-property-format",
              "shortDescription": {
                "text": "API7 (SSRF): URL-bearing property should declare `format: uri` and be reviewed for server-side fetch / allow-listing."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://docs.stoplight.io/docs/spectral/"
            }
          ]
        }
      },
